{
  "version": "1.0",
  "sources": ["models"],
  "maven": {
    "dependencies": ["software.amazon.smithy.typescript:smithy-typescript-codegen:0.24.0"]
  },
  "projections": {
    "typescript": {
      "plugins": {
        "typescript-codegen": {
          "package": "@moss/models",
          "packageVersion": "0.0.1",
          "emitServer": false,
          "emitClient": false,
          "emitTypesOnly": true,
          "unreferencedTypes": true,
          "disableDefaultValidation": true
        }
      }
    }
  }
}
